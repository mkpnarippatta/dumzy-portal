# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Server Configuration
PORT=3099
NODE_ENV=development

# External System Sync (Story 5.2)
ERPNEXT_API_URL=https://erpnext.example.com/api
ERPNEXT_API_KEY=your-erpnext-api-key
PMS_API_URL=https://pms.example.com/api
PMS_API_KEY=your-pms-api-key

# Sync Configuration
SYNC_MAX_RETRIES=3
SYNC_BACKOFF_MS=1000
SYNC_DRIFT_THRESHOLD=0.1
SYNC_POLL_INTERVAL_MS=5000

# Testing
MOCHA_TEST_MODE=false
